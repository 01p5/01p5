SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Customer config
export CUSTOMER_NAME="staging" # used for domain and resource naming, must be unique per customer
export CUSTOMER_DEPLOYMENT_PATH=$SCRIPT_DIR
echo "Customer Name: $CUSTOMER_NAME"
echo "Customer Deployment Path: $CUSTOMER_DEPLOYMENT_PATH"

# Cloudflare DNS (Terraform only — used by infra/terraform/aws/dns.tf).
# Leave blank if you've stripped the dns.tf module out for a self-hosted
# DNS path.
export TF_VAR_cloudflare_token=
export TF_VAR_cloudflare_zone_id=

# --- Olympus runtime credentials (mount into the dashboard pod) ---
# At least one provider key is required for the LLM-driven agents.
export ANTHROPIC_API_KEY=
export OPENAI_API_KEY=

# Optional LiteLLM gateway — if Olympus is fronted by LiteLLM rather
# than going direct to Anthropic/OpenAI, set both:
export OLYMPUS_LITELLM_API_KEY=
export OLYMPUS_LITELLM_API_URL=

# Per-deployment domain. Used by Cloudflare DNS records and the
# dashboard Ingress.
export DEPLOYMENT_DOMAIN_PREFIX=${CUSTOMER_NAME}

export TF_VAR_deployment_domain_prefix=${DEPLOYMENT_DOMAIN_PREFIX}
export TF_VAR_customer_name=${CUSTOMER_NAME}
export TF_VAR_customer_deployment_path=${CUSTOMER_DEPLOYMENT_PATH}

# Cluster backend selector. "aws" or "pve". Read by infra/terraform/main.tf
# to decide which submodule to instantiate. Switching providers is just
# changing this — no code edits.
export TF_VAR_provider_target="aws"

# Container registry the Helm chart pulls the dashboard image from.
# Used by `helm install --set image.repository=$DEPLOYMENT_REGISTRY_HOST/olympus/dashboard`.
export DEPLOYMENT_REGISTRY_HOST=
export DEPLOYMENT_REGISTRY_USERNAME=
export DEPLOYMENT_REGISTRY_PASSWORD=

### Proxmox path — fill these out only if you're using infra/terraform/pve.
### Skip if you're deploying to AWS only.
export TF_VAR_pve_username="user@pam"
export TF_VAR_pve_password=""
export TF_VAR_pve_http_host="127.0.0.1"
export TF_VAR_pve_host=""
export TF_VAR_pve_service_ip=""
export TF_VAR_pve_login_node="pve"
